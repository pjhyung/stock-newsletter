# ============================================================
# US Stock Newsletter - 환경변수 설정 예시
# 이 파일을 .env 로 복사한 후 실제 값을 입력하세요.
# cp .env.example .env
# ============================================================

# ── Gemini API (무료) ────────────────────────────────────────
# 발급: https://aistudio.google.com/app/apikey
# 무료 한도: 15 RPM / 1,000,000 TPD (매일 리셋)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Slack ────────────────────────────────────────────────────
# 앱 생성: https://api.slack.com/apps
# OAuth Scopes 필요: chat:write, reactions:read, channels:history
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_CHANNEL_ID=C0XXXXXXXXX

# ── 뉴스레터 설정 ─────────────────────────────────────────────
NEWSLETTER_AUTHOR=형

# ── 이메일 발송 (Resend API) ─────────────────────────────────
# 발급: https://resend.com → Sign up → API Keys → Create API Key
# 무료 플랜: 월 3,000건 / 일 100건
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# 발신 주소: 도메인 인증 전에는 onboarding@resend.dev 사용 (본인 이메일로만 발송 가능)
# 도메인 인증 후: newsletter@내도메인.com 형태로 변경 가능
EMAIL_FROM=onboarding@resend.dev
EMAIL_TO=받을이메일@gmail.com

# ── GitHub Pages URL ──────────────────────────────────────────
# 이메일 상단 "웹에서 보기" 링크로 사용
PAGES_BASE_URL=https://유저네임.github.io/stock-newsletter/
