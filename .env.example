# ============================================================
# US Stock Newsletter - 환경변수 설정 예시
# 이 파일을 .env 로 복사한 후 실제 값을 입력하세요.
# cp .env.example .env
# ============================================================

# ── Gemini API (무료) ────────────────────────────────────────
# 발급: https://aistudio.google.com/app/apikey
# 무료 한도: 15 RPM / 1,000,000 TPD (매일 리셋)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Slack ────────────────────────────────────────────────────
# 앱 생성: https://api.slack.com/apps
# OAuth Scopes 필요: chat:write, reactions:read, channels:history
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_CHANNEL_ID=C0XXXXXXXXX

# ── 뉴스레터 설정 ─────────────────────────────────────────────
NEWSLETTER_AUTHOR=형

# ── 이메일 발송 (Gmail SMTP) ─────────────────────────────────
# 앱 비밀번호 발급: Google 계정 → 보안 → 2단계인증 → 앱 비밀번호
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=your_gmail@gmail.com

# ── GitHub Pages URL ──────────────────────────────────────────
# 이메일 상단 "웹에서 보기" 링크로 사용
PAGES_BASE_URL=https://유저네임.github.io/stock-newsletter/
